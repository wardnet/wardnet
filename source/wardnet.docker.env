#
# Wardnet Development Environment — Configuration
# ─────────────────────────────────────────────────────────────────────────────
# CHANGE THESE two values before running docker compose up
#
# WARDNET_PI_IP  — static IP of your Wardnet Pi on your LAN
#                  find it by running on the Pi:
#                  ip addr show eth0 | grep 'inet '
#
# WARDNET_SUBNET — the /24 subnet that contains your Pi's IP
#                  Pi on 10.232.1.195  →  10.232.1.0/24
#                  Pi on 192.168.1.50  →  192.168.1.0/24
# ─────────────────────────────────────────────────────────────────────────────

WARDNET_PI_IP=10.232.1.195
WARDNET_SUBNET=10.232.1.0/24

# ─────────────────────────────────────────────────────────────────────────────
# Static IPs for test containers — must be free within WARDNET_SUBNET
# and must not conflict with the Pi or any other device on your LAN
# ─────────────────────────────────────────────────────────────────────────────
TEST_ALPINE_IP=10.232.1.210
TEST_UBUNTU_IP=10.232.1.211

# ─────────────────────────────────────────────────────────────────────────────
# Grafana UI port on your host machine
# Access at http://localhost:GRAFANA_PORT  (admin / admin)
# ─────────────────────────────────────────────────────────────────────────────
GRAFANA_PORT=7414