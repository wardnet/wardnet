{
  "name": "@wardnet/js",
  "version": "0.1.0",
  "description": "TypeScript SDK for the Wardnet network privacy gateway",
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "types": "./src/index.ts"
    }
  },
  "files": [
    "src"
  ],
  "scripts": {
    "type-check": "tsc --noEmit",
    "format": "prettier --write src/",
    "format:check": "prettier --check src/"
  },
  "devDependencies": {
    "prettier": "^3.8.1",
    "typescript": "~5.9.3"
  },
  "packageManager": "yarn@4.13.0"
}
