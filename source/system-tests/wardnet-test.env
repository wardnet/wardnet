# System test environment configuration.
#
# These values configure the podman/docker bridge network and container IPs
# for the system test environment.

# Pi's LAN IP (used by dev machine to reach the API and test agent).
WARDNET_PI_IP=10.232.1.10

# Test bridge network (must NOT overlap with the Pi's LAN subnet).
WARDNET_SUBNET=172.30.0.0/24
WARDNET_GATEWAY=172.30.0.1

# Test client containers
TEST_ALPINE_IP=172.30.0.10
TEST_UBUNTU_IP=172.30.0.11

# Mock WireGuard peers
MOCK_PEER_1_IP=172.30.0.20
MOCK_PEER_1_PORT=51820
MOCK_PEER_1_INTERNAL=10.99.1.1/24

MOCK_PEER_2_IP=172.30.0.21
MOCK_PEER_2_PORT=51820
MOCK_PEER_2_INTERNAL=10.99.2.1/24

# Wardnet daemon
WARDNET_API_PORT=7411
WARDNET_IDLE_TIMEOUT=5

# Test admin credentials
TEST_ADMIN_USER=admin
TEST_ADMIN_PASS=testpassword123
